            <li class="nav-item">
              <a class="nav-link <%= active === 'proyectos' ? 'active' : '' %>" href="/proyectos">
                Proyectos
              </a>
            </li>
             <% } %>
          <li class="nav-item">
            <a class="nav-link <%= (active === 'consult' ? 'active' : '') %>" href="/consult">Consulta</a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= (active === 'nueva' ? 'active' : '') %>" href="/nueva">Nueva muestra</a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= (active === 'navegacion' ? 'active' : '') %>" href="/navegacion">Navegación</a>
          </li>
          <li>
            <a class="nav-link <%= active === 'chat' ? 'active' : '' %>" href="/chat">Chat</a>
          </li>
          <li class="nav-item">
            <a class="nav-link <%= active === 'informacion' ? 'active' : '' %>" href="/informacion">
              Información adicional
            </a>
          </li>
          <% } %>
