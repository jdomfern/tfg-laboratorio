            <i class="bi bi-sun-fill"></i> Claro
          </button>
          <button id="btnDark" type="button" class="boton-tema">
            <i class="bi bi-moon-stars-fill"></i> Oscuro
          </button>
        </div>
        <% if (user) { %>
