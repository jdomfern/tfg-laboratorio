              <div class="rol-navbar">
                <%= user.role === 'administrador' ? 'Administrador' : 'Técnico' %>
              </div>
            </div>
          </div>
          <a class="btn btn-outline-light btn-sm" href="/logout">Salir</a>
          <% } else { %>
            <a class="btn btn-outline-light btn-sm" href="/login">Login</a>
            <a class="btn btn-warning btn-sm" href="/register">Registro</a>
            <% } %>
      </div>
      <div id="mensajeRegistro" class="mensaje-registro d-none"></div>
