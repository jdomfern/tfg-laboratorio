<%- include('partials/head', { title: 'Registro' }) %>
<%- include('partials/navbar') %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-9 col-lg-6">
      <div class="card shadow-sm">
        <div class="card-body p-4">
          <h2 class="h4 mb-3">Crear cuenta</h2>
          <p class="text-muted mb-4">Regístrate para acceder al sistema</p>
          <% if (error) { %>
            <div class="alert alert-danger"><%= error %></div>
          <% } %>
          <form method="POST" action="/register" class="row g-3">
            <div class="col-12">
              <label class="form-label" for="name">Nombre</label>
              <input class="form-control" type="text" id="name" name="name" required autocomplete="name">
            </div>
            <div class="col-12">
              <label class="form-label" for="email">Email</label>
              <input class="form-control" type="email" id="email" name="email" pattern="^[a-zA-Z0-9._%+-]+@aqualab\.com$"
              title="Introduce un correo corporativo válido, por ejemplo: usuario@aqualab.com" required autocomplete="email">
            </div>
            <div class="col-12">
              <label class="form-label" for="password">Contraseña</label>
              <div class="input-group">
              <input class="form-control" type="password" id="password" name="password" required autocomplete="new-password">
              <span class="input-group-text" id="verPassword" style="cursor:pointer;">
                <i class="bi bi-eye"></i>
              </span>
            </div>
            <div class="form-text">Recomendado: mínimo 8 caracteres.</div>
          </div>
            <div class="col-12 d-grid">
              <button class="btn btn-success btn-lg" type="submit">Crear cuenta</button>
            </div>
            <div class="col-12 small">
              ¿Ya tienes cuenta? <a href="/login">Inicia sesión</a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/foot') %>
