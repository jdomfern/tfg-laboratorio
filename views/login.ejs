<%- include('partials/head', { title: 'Login' }) %>
<%- include('partials/navbar') %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-12 col-md-8 col-lg-5">
      <div class="card shadow-sm">
        <div class="card-body p-4">
          <h2 class="h4 mb-3">Iniciar sesión</h2>
          <p class="text-muted mb-4">Accede al área de empleados del laboratorio</p>
          <% if (error) { %>
            <div class="alert alert-danger"><%= error %></div>
          <% } %>
          <form method="POST" action="/login" class="vstack gap-3">
            <div>
              <label class="form-label" for="email">Email</label>
              <input class="form-control" type="email" id="email" name="email" pattern="^[a-zA-Z0-9._%+-]+@aqualab\.com$"
              title="Introduce un correo corporativo válido, por ejemplo: usuario@aqualab.com" required autocomplete="email">
            </div>
            <div class="mb-3">
              <label class="form-label" for="password">Contraseña</label>
              <div class="input-group">
                <input class="form-control" type="password" id="password" name="password" required autocomplete="current-password">
                <span class="input-group-text" id="verPassword" style="cursor:pointer;">
                  <i class="bi bi-eye"></i>
                </span>
              </div>
            </div>
            <div class="form-check">
              <input class="form-check-input" type="checkbox" id="remember" name="remember" value="1">
              <label class="form-check-label" for="remember">Recordarme</label>
            </div>
            <button class="btn btn-primary btn-lg w-100" type="submit">Entrar</button>
            <div class="d-flex justify-content-between small">
              <a href="/register">¿No tienes cuenta? Regístrate</a>
              <a href="/forgot">¿Olvidaste la contraseña?</a>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</div>

<%- include('partials/foot') %>
