<%- include('partials/head', { title: 'Inicio' }) %>
  <%- include('partials/navbar') %>

    <div class="cabecera-inicio">
      <div class="container py-5">
        <div class="row align-items-center g-4">
          <div class="col-12 col-lg-7">
            <span class="insignia-inicio">Laboratorio en línea</span>
            <h1 class="titulo-inicio mt-3">Gestión de muestras de agua</h1>
            <p class="texto-inicio">
              Plataforma web para el registro, edición y consulta de muestras de agua.<br>
              Herramientas auxiliares para el técnico muestreador.
            </p>
            <div class="d-flex flex-wrap gap-2 mt-4">
              <a href="/nueva" class="btn btn-light btn-lg">Nueva muestra</a>
              <a href="/consult" class="btn btn-outline-light btn-lg">Consultar muestras</a>
            </div>
          </div>
          <div class="col-12 col-lg-5">
            <div class="panel-inicio">
              <div class="fila-panel">
                <span class="icono-panel"><i class="bi bi-droplet-half"></i></span>
                <div>
                  <h6 class="mb-1">Control técnico</h6>
                  <p class="mb-0">Parámetros fisico-químicos de muestras de agua</p>
                </div>
              </div>
              <div class="fila-panel">
                <span class="icono-panel"><i class="bi bi-wifi-off"></i></span>
                <div>
                  <h6 class="mb-1">Modo offline</h6>
                  <p class="mb-0">Registros sin dependencia de la cobertura disponible</p>
                </div>
              </div>
              <div class="fila-panel">
                <span class="icono-panel"><i class="bi bi-image"></i></span>
                <div>
                  <h6 class="mb-1">Evidencia visual</h6>
                  <p class="mb-0">Fotografías de los puntos de muestreo</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
    <div class="container py-5">
      <% if (user) { %>
        <div class="row g-3 mb-5 justify-content-center">
          <div class="col-6 col-md-4 col-lg">
            <a href="/nueva" class="text-decoration-none">
              <div class="card tarjeta-principal clickable h-100">
                <div class="card-body text-center p-4">
                  <div class="circulo-icono mb-3"><i class="bi bi-plus-circle"></i></div>
                  <h5 class="card-title titulo-tarjeta">Nueva muestra</h5>
                  <p class="card-text text-muted mb-0">
                    Registro de parámetros
                  </p>
                </div>
              </div>
            </a>
          </div>
          <div class="col-6 col-md-4 col-lg">
            <a href="/consult" class="text-decoration-none">
              <div class="card tarjeta-principal clickable h-100">
                <div class="card-body text-center p-4">
                  <div class="circulo-icono mb-3"><i class="bi bi-search"></i></div>
                  <h5 class="card-title titulo-tarjeta">Consulta</h5>
                  <p class="card-text text-muted mb-0">
                    Revisión y edición de muestras registradas
                  </p>
                </div>
              </div>
            </a>
          </div>
          <div class="col-6 col-md-4 col-lg">
            <a href="/navegacion" class="text-decoration-none">
              <div class="card tarjeta-principal clickable h-100">
                <div class="card-body text-center p-4">
                  <div class="circulo-icono mb-3"><i class="bi bi-map"></i></div>
                  <h5 class="card-title titulo-tarjeta">Navegación</h5>
                  <p class="card-text text-muted mb-0">
                    Localización de los puntos de muestreo
                  </p>
                </div>
              </div>
            </a>
          </div>
          <% if (user.role==='administrador' ) { %>
            <div class="col-6 col-md-4 col-lg">
              <a href="/proyectos" class="text-decoration-none">
                <div class="card tarjeta-principal clickable h-100">
                  <div class="card-body text-center p-4">
                    <div class="circulo-icono mb-3"><i class="bi bi-folder-plus"></i></div>
                    <h5 class="card-title titulo-tarjeta">Proyectos</h5>
                    <p class="card-text text-muted mb-0">
                      Alta y gestión de proyectos de aguas
                    </p>
                  </div>
                </div>
              </a>
            </div>
            <% } %>
              <div class="col-6 col-md-4 col-lg">
                <a href="/chat" class="text-decoration-none">
                  <div class="card tarjeta-principal clickable h-100">
                    <div class="card-body text-center p-4">
                      <div class="circulo-icono mb-3">
                        <i class="bi bi-chat-dots"></i>
                      </div>
                      <h5 class="card-title titulo-tarjeta">Chat</h5>
                      <p class="card-text text-muted mb-0">
                        Comunicación interna
                      </p>
                    </div>
                  </div>
                </a>
              </div>
              <div class="col-12 col-sm-6 col-md-4 col-lg">
                  <a href="/informacion" class="text-decoration-none">
                    <div class="card tarjeta-principal clickable h-100">
                      <div class="card-body text-center p-4">
                        <div class="circulo-icono mb-3">
                          <i class="bi bi-bar-chart-line"></i>
                        </div>
                        <h5 class="card-title titulo-tarjeta">Información adicional</h5>
                        <p class="card-text text-muted mb-0">
                          Gráficos y datos de interés
                        </p>
                      </div>
                    </div>
                  </a>
                </div>
        </div>
        <% } %>
          <div id="carouselCampo" class="carousel slide carousel-fade mb-5" data-bs-ride="carousel">
            <div class="carousel-indicators">
              <button type="button" data-bs-target="#carouselCampo" data-bs-slide-to="0" class="active"></button>
              <button type="button" data-bs-target="#carouselCampo" data-bs-slide-to="1"></button>
              <button type="button" data-bs-target="#carouselCampo" data-bs-slide-to="2"></button>
            </div>
            <div class="carousel-inner rounded-4 overflow-hidden shadow-sm">
              <div class="carousel-item active">
                <img src="/img/campo1.jpg" class="d-block w-100 imagen-carrusel" alt="Trabajo de campo">
                <div class="carousel-caption texto-carrusel">
                  <h5 class="mb-1">Trabajo en campo</h5>
                  <p class="mb-0">Herramienta para condiciones reales de muestreo</p>
                </div>
              </div>
              <div class="carousel-item">
                <img src="/img/campo2.jpg" class="d-block w-100 imagen-carrusel" alt="Punto de muestreo">
                <div class="carousel-caption texto-carrusel">
                  <h5 class="mb-1">Punto de muestreo</h5>
                  <p class="mb-0">Localización en maps del punto a muestrear</p>
                </div>
              </div>
              <div class="carousel-item">
                <img src="/img/campo3.jpg" class="d-block w-100 imagen-carrusel" alt="Sincronización">
                <div class="carousel-caption texto-carrusel">
                  <h5 class="mb-1">Sincronización de registros</h5>
                  <p class="mb-0">Operativa incluso en condiciones sin cobertura</p>
                </div>
              </div>
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#carouselCampo" data-bs-slide="prev">
              <span class="carousel-control-prev-icon"></span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#carouselCampo" data-bs-slide="next">
              <span class="carousel-control-next-icon"></span>
            </button>
          </div>
          <div class="text-center mb-4">
            <h3 class="titulo-tarjeta">Tecnologías utilizadas</h3>
          </div>
          <div class="row g-3 justify-content-center">
            <div class="col-6 col-md-4 col-lg">
              <a href="https://nodejs.org/es" target="_blank" rel="noopener noreferrer" class="text-decoration-none">
                <div class="card tarjeta-principal h-100">
                  <div class="card-body text-center p-4">
                    <div class="circulo-icono mb-3 circulo-icono-tec">
                      <img src="/img/node_icon.png" alt="Node.js" class="icono-tecnologia">
                    </div>
                    <h5 class="card-title titulo-tarjeta mb-0">Node.js</h5>
                  </div>
                </div>
              </a>
            </div>
            <div class="col-6 col-md-4 col-lg">
              <a href="https://expressjs.com/es/" target="_blank" rel="noopener noreferrer"
                class="text-decoration-none">
                <div class="card tarjeta-principal h-100">
                  <div class="card-body text-center p-4">
                    <div class="circulo-icono mb-3 circulo-icono-tec">
                      <img src="/img/express_icon.png" alt="Express" class="icono-tecnologia">
                    </div>
                    <h5 class="card-title titulo-tarjeta mb-0">Express</h5>
                  </div>
                </div>
              </a>
            </div>
            <div class="col-6 col-md-4 col-lg">
              <a href="https://sequelize.org/" target="_blank" rel="noopener noreferrer" class="text-decoration-none">
                <div class="card tarjeta-principal h-100">
                  <div class="card-body text-center p-4">
                    <div class="circulo-icono mb-3 circulo-icono-tec">
                      <img src="/img/sequelize_icon.png" alt="Sequelize" class="icono-tecnologia">
                    </div>
                    <h5 class="card-title titulo-tarjeta mb-0">Sequelize</h5>
                  </div>
                </div>
              </a>
            </div>
            <div class="col-6 col-md-4 col-lg">
              <a href="https://www.mysql.com/" target="_blank" rel="noopener noreferrer" class="text-decoration-none">
                <div class="card tarjeta-principal h-100">
                  <div class="card-body text-center p-4">
                    <div class="circulo-icono mb-3 circulo-icono-tec">
                      <img src="/img/mysql_icon.png" alt="MySQL" class="icono-tecnologia">
                    </div>
                    <h5 class="card-title titulo-tarjeta mb-0">MySQL</h5>
                  </div>
                </div>
              </a>
            </div>
            <div class="col-6 col-md-4 col-lg">
              <a href="https://getbootstrap.com/" target="_blank" rel="noopener noreferrer"
                class="text-decoration-none">
                <div class="card tarjeta-principal h-100">
                  <div class="card-body text-center p-4">
                    <div class="circulo-icono mb-3 circulo-icono-tec">
                      <img src="/img/bootstrap_icon.png" alt="Bootstrap" class="icono-tecnologia">
                    </div>
                    <h5 class="card-title titulo-tarjeta mb-0">Bootstrap</h5>
                  </div>
                </div>
              </a>
            </div>
            <div class="col-6 col-md-4 col-lg">
              <a href="https://playwright.dev/" target="_blank" rel="noopener noreferrer" class="text-decoration-none">
                <div class="card tarjeta-principal h-100">
                  <div class="card-body text-center p-4">
                    <div class="circulo-icono mb-3 circulo-icono-tec">
                      <img src="/img/playwright_logo.svg" alt="Playwright" class="icono-tecnologia">
                    </div>
                    <h5 class="card-title titulo-tarjeta mb-0">Playwright</h5>
                  </div>
                </div>
              </a>
            </div>
          </div>
    </div>

    <%- include('partials/foot') %>